# Copy this file to .env and fill in your values.
# Never commit your real .env file to version control.

FLASK_ENV=development
FLASK_DEBUG=1

# A long random string — used to sign JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-secret-key

# SQLite database path (relative to the backend/ folder)
DATABASE_URL=sqlite:///instance/travel_ledger.db

# CORS — the URL of your frontend dev server
CORS_ORIGINS=http://localhost:3000
